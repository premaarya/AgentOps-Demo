# Contract AgentOps Demo - Environment Variables
DEMO_MODE=simulated              # "live" or "simulated"

# Azure AI Foundry - Required for live mode
FOUNDRY_API_KEY=                  # Azure OpenAI / AI Foundry API key
FOUNDRY_ENDPOINT=                 # Azure OpenAI endpoint (e.g., https://<resource>.openai.azure.com)
FOUNDRY_PROJECT_ENDPOINT=         # AI Foundry project endpoint (optional, defaults to FOUNDRY_ENDPOINT)
FOUNDRY_MODEL=gpt-4o             # Model deployment name
FOUNDRY_MODEL_SWAP=gpt-4o-mini   # Model for swap/drift demo

GATEWAY_PORT=8000
DASHBOARD_PORT=3000
MCP_BASE_PORT=9001               # MCP servers use 9001-9008
LOG_LEVEL=INFO
