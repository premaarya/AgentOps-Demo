# Microsoft Agent Framework Configuration Template
# Copy this file to .env and fill in your actual values

# ===== MICROSOFT FOUNDRY CONFIGURATION =====
# Get these from your Azure AI Studio / Microsoft Foundry project
FOUNDRY_ENDPOINT="https://your-project.region.models.ai.azure.com"
FOUNDRY_API_KEY="your-foundry-api-key-here"

# ===== MODEL CONFIGURATION =====
# Pinned model versions for consistency (date-suffixed)
PRIMARY_MODEL="gpt-5.1-2026-01-15"
FALLBACK_MODEL="gpt-4o-2026-01-15"
EMERGENCY_MODEL="gpt-4o-mini-2026-01-15"

# Model parameters
AGENT_TEMPERATURE=0.0
AGENT_MAX_TOKENS=2048
AGENT_TIMEOUT=30

# ===== TRACING & OBSERVABILITY =====
TRACING_ENABLED=true
# Optional: OTLP endpoint for traces (leave empty for console logging)
# TRACE_ENDPOINT="http://localhost:4318/v1/traces"

# ===== EVALUATION CONFIGURATION =====
EVALUATION_ENABLED=true
BASELINE_COMPARISON=true

# ===== HUMAN-IN-THE-LOOP =====
HITL_ENABLED=true
HITL_TIMEOUT_HOURS=24
LEGAL_REVIEW_EMAIL="legal-team@your-company.com"

# ===== PERFORMANCE & RELIABILITY =====
MAX_RETRIES=3
RETRY_BACKOFF_BASE=1.0
CIRCUIT_BREAKER_THRESHOLD=5

# ===== DEVELOPMENT SETTINGS =====
# Set to true for development/testing
DEBUG=false
LOG_LEVEL="INFO"

# ===== OPTIONAL: AZURE CONFIGURATION =====
# If using Azure Identity instead of API keys
# AZURE_TENANT_ID="your-tenant-id"
# AZURE_CLIENT_ID="your-client-id"
# AZURE_CLIENT_SECRET="your-client-secret"

# ===== MCP SERVER ENDPOINTS =====
# These should match your MCP server configuration
# Default ports if running locally with npm run start:mcp-servers
MCP_INTAKE_URL="http://localhost:9001"
MCP_EXTRACTION_URL="http://localhost:9002"
MCP_COMPLIANCE_URL="http://localhost:9003"
MCP_WORKFLOW_URL="http://localhost:9004"
MCP_AUDIT_URL="http://localhost:9005"
MCP_EVAL_URL="http://localhost:9006"
MCP_DRIFT_URL="http://localhost:9007"
MCP_FEEDBACK_URL="http://localhost:9008"