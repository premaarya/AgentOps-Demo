{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contract-agentops/execution-status",
  "title": "ExecutionStatus",
  "type": "object",
  "additionalProperties": false,
  "required": ["workflow_instance_id", "workflow_package_id", "contract_id", "status", "current_step", "updated_at"],
  "properties": {
    "workflow_instance_id": { "type": "string" },
    "workflow_package_id": { "type": "string" },
    "contract_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["accepted", "running", "waiting_review", "completed", "failed", "cancelled"]
    },
    "current_step": { "type": "string" },
    "trace_id": { "type": ["string", "null"] },
    "updated_at": { "type": "string" }
  }
}