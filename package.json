{
	"name": "contract-agentops-demo",
	"version": "1.0.0",
	"description": "Contract AgentOps Demo - Microsoft Foundry",
	"private": true,
	"type": "module",
	"workspaces": ["gateway", "mcp-servers/*", "agents"],
	"scripts": {
		"build": "npm run build --workspaces --if-present",
		"start": "tsx start.ts",
		"start:gateway": "npm run start -w gateway",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"typecheck": "tsc --build"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"devDependencies": {
		"@types/node": "^20.14.0",
		"typescript": "^5.5.0",
		"tsx": "^4.19.0",
		"vitest": "^4.0.18",
		"@biomejs/biome": "^1.9.0"
	}
}
